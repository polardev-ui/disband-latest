{
  "name": "disband",
  "version": "0.5.1",
  "author": "Josh Clark <joshclark@wsgpolar.me>",
  "private": true,
  "description": "Disband — a cross-platform (macOS, Windows, Linux, Web) app built with Next.js + Tauri + Supabase.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:tauri": "node scripts/tauri-next-build.mjs",
    "start": "next start",
    "lint": "next lint",
    "export": "next build",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "sync:auth-emails": "node scripts/sync-auth-email-templates.mjs",
    "verify:auth-emails": "node scripts/sync-auth-email-templates.mjs --verify",
    "send:mobile-launch": "node scripts/send-mobile-launch.mjs",
    "version:set": "node scripts/set-version.mjs",
    "release:next": "node scripts/next-release-version.mjs",
    "git:push-main": "git push origin refs/heads/main",
    "git:fix-main-ref": "node scripts/fix-main-ref-conflict.mjs --delete-tag"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tauri-plugin-macos-permissions-api": "2.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
