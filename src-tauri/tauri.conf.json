{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Disband",
  "version": "0.5.1",
  "identifier": "me.wsgpolar.disband",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:tauri"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Disband",
        "label": "main",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' blob: data: media: mediastream: tauri: asset: http://asset.localhost https://asset.localhost",
        "connect-src": "'self' blob: data: ipc: http://ipc.localhost https://*.supabase.co wss://*.supabase.co https://api.wsgpolar.me https://api.github.com https://*.wsgpolar.me wss: ws: http://localhost:* ws://localhost:*",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' blob: data: https: http:",
        "media-src": "'self' blob: data: mediastream: https: http:",
        "font-src": "'self' data:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "SocialNetworking",
    "shortDescription": "One codebase, every platform.",
    "longDescription": "Disband — a cross-platform app for macOS, Windows, Linux and the Web, built from a single Next.js codebase.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
